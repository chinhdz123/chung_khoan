APP_NAME=KyLuat DauTu
ENV=dev
LOG_LEVEL=INFO
SQLITE_PATH=./data/chung_khoan.db
TZ=Asia/Ho_Chi_Minh

# Scheduler
ETL_HOUR=15
ETL_MINUTE=30
ADVICE_HOUR=6
ADVICE_MINUTE=0

# Gemini CLI
GEMINI_ENABLED=true
GEMINI_CMD=C:\\Users\\HLC\\AppData\\Roaming\\npm\\gemini.cmd
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=180
GEMINI_MAX_RETRIES=2

# Anti overuse policy
AI_MAX_CALLS_GLOBAL_PER_DAY=30
AI_MAX_CALLS_PER_USER_PER_DAY=1
AI_TOP_SYMBOLS_PER_REPORT=5
AI_MIN_SCORE_DELTA_FOR_CHANGE=10
AI_MIN_RISK_DELTA_FOR_CHANGE=8

# Vnstock / market data
VNSTOCK_API_KEY=
VNSTOCK_MAX_REQUESTS_PER_MIN=18
VNSTOCK_RETRY_ATTEMPTS=3
VNSTOCK_ENRICH_MARKET_FLOWS=true
EOD_MARKET_API_URL=https://api-finfo.vndirect.com.vn/v4/stock_prices
EOD_FOREIGN_API_URL=https://api-finfo.vndirect.com.vn/v4/foreigns
EOD_PROPRIETARY_API_URL=https://api-finfo.vndirect.com.vn/v4/proprietary_trading
EOD_MARKET_MAX_BACK_DAYS=5
